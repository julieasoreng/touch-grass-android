@@ -0,0 +1,36 @@
+package com.julieasoreng.touchgrass.ui.goals
+
+import androidx.compose.ui.graphics.Color
+import com.julieasoreng.touchgrass.ui.theme.GoalsButter
+import com.julieasoreng.touchgrass.ui.theme.GoalsDustyRose
+import com.julieasoreng.touchgrass.ui.theme.GoalsLavender
+import com.julieasoreng.touchgrass.ui.theme.GoalsMint
+import com.julieasoreng.touchgrass.ui.theme.GoalsPeach
+import com.julieasoreng.touchgrass.ui.theme.GoalsSky
+
+val activityColorPalette = listOf(
+    GoalsMint,
+    GoalsPeach,
+    GoalsLavender,
+    GoalsDustyRose,
+    GoalsSky,
+    GoalsButter
+)
+
+val activityIconOptions = listOf("📖", "🎸", "📚", "🎨", "🏃", "✍️", "🧘", "🎹", "💃", "📓", "🚶", "🌱")
+
+private val knownActivityIcons = mapOf(
+    "reading" to "📖",
+    "writing" to "✍️",
+    "painting" to "🎨",
+    "dancing" to "💃",
+    "exercise" to "🏃",
+    "journaling" to "📓"
+)
+
+fun colorForIndex(index: Int): Color = activityColorPalette[index % activityColorPalette.size]
+
+fun defaultIconFor(activityName: String, fallbackIndex: Int): String {
+    return knownActivityIcons[activityName.trim().lowercase()]
+        ?: activityIconOptions[fallbackIndex % activityIconOptions.size]
+}
